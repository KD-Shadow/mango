#    в–‘в–Ҳв–Җв–Җв–‘в–Җв–Ҳв–Җв–‘в–Җв–Ҳв–Җв–‘в–Җв–Ҳв–Җв–‘в–Ҳв–Җв–Җв–‘в–Ҳв–Җв–Ҳв–‘в–Ҳв–Җв–Ҳв–‘в–Ҳв–Җв–„в–‘в–Ҳв–Җв–Җ
#    в–‘в–Ҳв–‘в–Ҳв–‘в–‘в–Ҳв–‘в–‘в–‘в–Ҳв–‘в–‘в–‘в–Ҳв–‘в–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘в–Ҳв–Җв–„в–‘в–Ҳв–Җв–Җ
#    в–‘в–Җв–Җв–Җв–‘в–Җв–Җв–Җв–‘в–‘в–Җв–‘в–‘в–Җв–Җв–Җв–‘в–Җв–Җв–Җв–‘в–Җв–‘в–Җв–‘в–Җв–Җв–Җв–‘в–Җв–‘в–Җв–‘в–Җв–Җв–Җ


# в”Җв”Җ security & secrets (critical) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# !!! CRITICAL: Never commit secrets
# These patterns attempt to catch common credential filenames.
.env
.env.local
.env.*.local
*.pem
*.key
*.gpg
id_rsa
id_rsa.pub
_secrets/
secrets/

# Heuristic blocking for files containing sensitive keywords
# (Be careful, this might block legitimate files like 'token_parser.zsh')
*token*
*secret*
*password*


# в”Җв”Җ zsh internal artifacts в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# ------------------------------------------------------------------------------
# Bytecode Compilation
# Zsh can compile scripts into binary (*.zwc) for faster startup.
# These are machine-specific and should never be shared.
# ------------------------------------------------------------------------------
*.zwc

# ------------------------------------------------------------------------------
# Completion Cache
# Zsh dumps the state of the completion system to a file to speed up loading.
# This file is auto-generated and contains system-specific paths.
# ------------------------------------------------------------------------------
.zcompdump*
.zcompdump
zcompdump-*

# ------------------------------------------------------------------------------
# Shell History
# Contains your executed commands. Committing this is a massive security risk.
# ------------------------------------------------------------------------------
.zsh_history
.bash_history
.lesshst
.history
.zhistory


# в”Җв”Җ user customization (hooks) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Ignore/
# A dedicated scratchpad directory for quick tests
Ignore/
_IGNORE
Scratch/
.zsh_backups/

# Local Overrides
# These files allow users to define machine-specific config (e.g., work vs home)
# without polluting the main repository.
user.local.conf
user.private.conf
user.secret.conf


# в”Җв”Җ os & system files в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# macOS Metadata
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux / KDE / Gnome
*~
.directory
.Trash-*
.fuse_hidden*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# в”Җв”Җ editors & ides в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# VS Code
# We ignore the folder generally, but whitelisting (!) specific config files
# allows us to share recommended settings while ignoring user workspace state.
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Vim / Neovim
# Swap files (crash recovery) and backups
*.swp
*.swo
*.swn
[._]*.un~
Session.vim

# JetBrains (IntelliJ, PyCharm, etc)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-workspace
*.sublime-project


# в”Җв”Җ dependencies & logs в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Project Dependencies
node_modules/
bower_components/
vendor/
dist/
build/
target/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# Logs
# Catches standard log files and the custom logs generated by our
# _zsh_debug_startup function.
*.log
logs/
npm-debug.log*
yarn-debug.log*
zsh-debug.log
zsh-profiler.log
/zsh/conf.d/PR.zsh
/temp.zsh
Tools
test*

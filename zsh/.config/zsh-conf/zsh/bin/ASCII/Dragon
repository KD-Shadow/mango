# ==============================================================================
# [1] CONFIGURATION
# ==============================================================================

# Define Colors using Zsh ANSI syntax
# \e[1m  = Bold
# \e[91m = Bright Red
typeset -r RED_BOLD=$'\e[1;91m'
typeset -r RESET=$'\e[0m'

# ==============================================================================
# [2] MAIN EXECUTION
# ==============================================================================

main() {

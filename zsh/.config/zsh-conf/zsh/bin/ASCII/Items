#  :: Random Art Generator
#  :: Randomly renders Cosmo, 1-Up Mushroom, or Burger.
#  :: Optimized for Zsh.
#  :: Updated By: GitHub@adityastomar67
#
#  USAGE:
#      1. Make executable: chmod +x Items
#      2. Run:             ./Items

# ==============================================================================
# [1] CONFIGURATION & SHARED COLORS
# ==============================================================================

typeset -r E=$'\e['
typeset -r X="${E}0m"  # Reset

# Cosmo / Mushroom Colors (Standard ANSI)
typeset -r K="${E}1;30m" # Bold Black
typeset -r B="${E}34m"   # Blue
typeset -r P="${E}35m"   # Purple
typeset -r G="${E}32m"   # Green
typeset -r W="${E}97m"   # Bright White
typeset -r S="${E}93m"   # Bright Yellow (Skin)

# ==============================================================================
# [2] ART DEFINITIONS
# ==============================================================================

# 1. Cosmo Character Art (by lantlos)
render_cosmo() {
    cat << EOF
    ${K} ██████${X}
   ${K}██${X}██${B}██${K}██${B}██${X}
   ${K}██${X}██${B}██${K}██${B}██${X}
   ${K}██████${P}██████${X}
   ${K}████${X}████${K}██${X}
 ${K}████${X}████████${K}██${X}
 ${K}████${X}████████${K}██${X}
 ${K}████${X}████████${K}██${X}
   ${K}████${X}████${K}██${X}
  ${K}███${P}███   ████${X}
EOF
}

# 2. 1-Up Mushroom (Retro Style)
render_mushroom() {
    cat << EOF
      ${G}▄▄▄▄▄▄▄▄${X}
    ${G}▄▄${W}████${G}▄▄${W}██${G}▄▄${X}
   ${G}▄${W}██████${G}▄▄${W}████${G}▄${X}
   ${G}▄${W}██████${G}▄▄${W}████${G}▄${X}
   ${G}██${G}▄▄▄▄▄▄▄▄${G}██${X}
    ${K}█${S}██${K}█${S}████${K}█${S}██${K}█${X}
    ${K}█${S}██${K}█${S}████${K}█${S}██${K}█${X}
    ${K}█${S}██████████${K}█${X}
     ${K}▀▀▀▀▀▀▀▀▀▀${X}
EOF
}


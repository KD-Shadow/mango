# ==============================================================================
# [1] SYSTEM INFO HELPERS
# ==============================================================================

get_os() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sw_vers -productName
    else
        # Source the file to get variables without spawning awk
        [[ -f /etc/os-release ]] && source /etc/os-release && print "${PRETTY_NAME}" || print "Linux"
    fi
}

get_kernel() {
    uname -r
}

get_uptime() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        # macOS uptime format is different, simplify it
        uptime | awk -F'(up |,| users)' '{print $2}' | xargs
    else
        uptime -p | sed 's/up //'
    fi
}

get_pkgs() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        # Check Brew or MacPorts
        if command -v brew >/dev/null; then
            print "$(brew list --formula | wc -l) (brew)"
        elif command -v port >/dev/null; then
             print "$(port installed | wc -l) (port)"
        else
             print "0"
        fi
        return
    fi

    # Linux Package Managers
    local -A managers=(
        "xbps-install" "xbps-query -l"
        "apk"          "apk search"
        "pacman"       "pacman -Q"
        "dnf"          "dnf list installed"
        "rpm"          "rpm -qa"
        "apt"          "apt list --installed"
        "eopkg"        "eopkg li"
        "nix"          "nix-env -qa --installed '*'"
    )

    for cmd query in ${(kv)managers}; do
        if command -v "$cmd" >/dev/null; then
            # Run query, count lines. Subtract 1 for apt header if needed.
            local count=$(eval "$query" 2>/dev/null | wc -l)
            [[ "$cmd" == "apt" ]] && ((count--))
            print "$count"
            return
        fi
    done
    print "0"
}

get_shell() {
    print "${SHELL##*/}"
}

get_mem() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        # macOS Memory
        local total=$(sysctl -n hw.memsize)
        # Convert bytes to MB
        print "$(( total / 1024 / 1024 )) MB"
    else
        # Linux Memory
        free --mega | awk 'NR == 2 { print $3" MB" }'
    fi
}

get_disk() {
    # Portable DF check
    df -h / | awk 'NR==2 {print $3 " / " $2}'
}

get_wm() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        print "Aqua"
        return
    fi

    # Linux WM/DE Detection
    local wm="${XDG_CURRENT_DESKTOP#*:}"
    [[ -z "$wm" ]] && wm="$DESKTOP_SESSION"

    if [[ -z "$wm" && -n "$DISPLAY" ]]; then
        # Try finding process names for common WMs
        local wms=(sway kiwmi wayfire sowm catwm fvwm dwm 2bwm monsterwm tinywm xmonad bspwm i3)
        for w in $wms; do
            if pgrep -x "$w" >/dev/null; then
                wm="$w"
                break
            fi
        done
    fi
    print "${wm:-Unknown}"
}

get_init() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        print "launchd"
    elif pidof -q systemd; then
        print "systemd"
    elif [[ -f '/sbin/openrc' ]]; then
        print "openrc"
    elif [[ -f '/sbin/dinit' ]]; then
        print "dinit"
    else
        print "init"
    fi
}


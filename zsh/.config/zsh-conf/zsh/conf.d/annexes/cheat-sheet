# ------------------------------------------------------------------------------
# Function: cht
# Description:
#   An interactive, terminal-based client for cheat.sh.
#   It allows users to quickly look up syntax, code snippets, and command usage
#   without leaving the command line.
#
#   How it works:
#   1. Displays a searchable menu of languages/tools using FZF.
#   2. Accepts a query (e.g., "reverse list" or "commit").
#   3. Fetches the result from cheat.sh via cURL.
#   4. Displays the output with syntax highlighting (using 'bat' or 'less').
#   5. Loops back to the query prompt for rapid follow-up questions.
#
# Features:
#   - FZF Menu: Fuzzy search through supported languages.
#   - Context Icons: Nerd Font icons for visual parsing.
#   - Syntax Highlighting: Auto-detects 'bat' for colorized output.
#   - Smart URL Handling: Handles cheat.sh's specific API routing (utils vs langs).
#
# Usage:
#   cheat-sheet
#
# Dependencies:
#   - fzf  : Required for the selection menu.
#   - curl : Required to fetch data from the internet.
#   - bat  : Optional (Highly Recommended) for syntax highlighting.
# ------------------------------------------------------------------------------


# 0. Safety & Environment Setup
# --------------------------------------------------------------------------
# emulate -L zsh : Ensures the function runs with standard Zsh options, regardless
#                  of the user's global config (prevents word-splitting issues).
# no_notify      : Prevents "Job finished" messages from cluttering the UI.
emulate -L zsh
# setopt localoptions no_notify no_monitor

# Check for critical dependencies before starting
if ! (( $+commands[fzf] )); then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} 'fzf' is required for this command."
    return 1
fi

if ! (( $+commands[curl] )); then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} 'curl' is required."
    return 1
fi

# --------------------------------------------------------------------------
# 1. Configuration & Data
# --------------------------------------------------------------------------

# Icon Map: Associates languages with Nerd Font icons.
# To add a new language, simply add "name" "icon" to this list.
typeset -A icons
icons=(
    python "оңј" go "оҳ§" lua "оҳ " cpp "оҳқ" rust "оһЁ" js "оһҒ"
    typescript "оҳЁ" bash "оҜҠ" zsh "п’ү" html "оң¶" css "оқү"
    java "оңё" php "оҳҲ" c "оҳһ" swift "оқ•" kotlin "оҳҙ"
    git "пҮ“" docker "пҢҲ" kubectl "пҙұ" tmux "оҜҲ" vim "оҹ…"
    tar "пҶҮ" xargs "п„ " awk "пғ¬" sed "пғ„" find "пЎҲ" curl "пғӯ"
)
local default_icon="п„Ё"

# State Machine Variables
# We use a state machine (MENU -> QUERY) to allow the user to go 'back'
# without restarting the function.
local state="MENU"
local clean_selected=""
local url_sep="/"

# Trap Ctrl+C (INT) to exit the function cleanly,
# rather than killing the entire shell session.
trap "return" INT

# --------------------------------------------------------------------------
# 2. The Main Loop
# --------------------------------------------------------------------------
while true; do

    # === STATE: MENU SELECTION ===
    # Displays the language/tool list
    if [[ "$state" == "MENU" ]]; then

        # Build the list for FZF (Icon + Name)
        local list_content=""
        for key in "${(@k)icons}"; do
            list_content+="${icons[$key]}  $key\n"
        done
        # Remove trailing newline to prevent an empty row in FZF
        list_content="${list_content%\\n}"

        # Launch FZF
        # -k2 : Sort by the 2nd column (the text name, not the icon)
        local selection
        selection=$(print -e "$list_content" | sort -k2 | fzf \
            --ansi \
            --info=hidden \
            --height=45% --layout=reverse --border --margin=1 --padding=1 \
            --prompt=" пҖӮ  " \
            --header="  [Esc] Exit " \
            --color='header:blue,prompt:yellow,pointer:red,marker:green,bg+:236' \
        )

        # Handle User Exit (Esc or Ctrl+C in FZF)
        if [[ -z "$selection" ]]; then
            print -e "${COLOR[GREY]}Goodbye!${COLOR[RESET]}"
            return 0
        fi

        # Extract the raw name (Column 2) stripping the icon
        clean_selected=$(print "$selection" | awk '{print $2}')

        # API Logic: Determine URL separator
        # Cheat.sh has a quirk:
        # - Languages use '/' (e.g. cht.sh/python/print)
        # - Core Utils use '~' (e.g. cht.sh/git~commit)
        # We check if the selection is in our 'utils' list to apply the correct char.
        local utils=("tar" "xargs" "awk" "sed" "find" "git" "docker" "kubectl" "tmux" "vim" "curl")

        # Zsh Array search: (r) flag checks if value is in array
        if [[ ${utils[(r)$clean_selected]} == "$clean_selected" ]]; then
            url_sep="~"
        else
            url_sep="/"
        fi

        state="QUERY"
    fi

    # === STATE: QUERY INPUT ===
    # Accepts the search term for the selected language
    if [[ "$state" == "QUERY" ]]; then
        print ""
        local icon="${icons[$clean_selected]:-$default_icon}"

        # UI Header: Shows current context (e.g., Python)
        print -e "${COLOR[GREY]}в•ӯв”Җ ${COLOR[BLUE]}${icon}  ${clean_selected:u} ${COLOR[GREY]}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${COLOR[RESET]}"

        # Read Input
        # Using 'read' with a custom manually constructed prompt for better styling
        print -ne "${COLOR[GREY]}в•°в”Җ${COLOR[GREEN]}пҒ”${COLOR[RESET]} Query ${COLOR[GREY]}([b]ack/[q]uit):${COLOR[RESET]} "
        read query

        # Handle Navigation Commands
        case "$query" in
            b|back|menu)
                state="MENU"
                continue
                ;;
            q|quit|exit|"")
                print -e "${COLOR[GREY]}Goodbye!${COLOR[RESET]}"
                return 0
                ;;
        esac

        # URL Construction
        # 1. Convert spaces to '+' (e.g., "reverse list" -> "reverse+list")
        # 2. Build full URL: cht.sh/lang/query
        local safe_query=$(print "$query" | tr ' ' '+')
        local url="cht.sh/${clean_selected}${url_sep}${safe_query}"

        print -e "   ${COLOR[GREY]}пӣҷ  Fetching...${COLOR[RESET]}"

        # Output Handling & Paging
        if (( $+commands[bat] )); then
            # Option A: 'bat' (Preferred)
            # We append '?T' to the URL to tell cheat.sh to send plain text (no ANSI),
            # allowing 'bat' to apply its own superior syntax highlighting.
            curl -s "$url?T" | bat --style=grid --color=always --language="$clean_selected" --paging=always
        else
            # Option B: 'less' (Fallback)
            # We do NOT use '?T', allowing cheat.sh to send its default ANSI colors.
            # 'less -R' allows those raw color codes to be displayed.
            curl -s "$url" | less -R
        fi
    fi
done

#!/usr/bin/env zsh

# ------------------------------------------------------------------------------
# Function: _git_wrapper
# Description:
#   A "High-Fidelity" wrapper for the Git CLI, designed to dramatically improve
#   the developer experience by replacing standard Git output with a modern,
#   colorized, icon-driven, and highly interactive Terminal UI.
#
#   How it works:
#       1. Intercepts common Git commands (`clone`, `pull`, `status`, `log`).
#       2. Validates if the command is running interactively (TTY) or piped.
#       3. If piped, it falls back to the raw `git` command to prevent breaking scripts.
#       4. If interactive, it routes to custom sub-modules that parse Git's raw text
#          stream and reconstruct it visually.
#
# Sub-Modules:
#    __clone  : Adds a clean header, dynamic progress bars, and post-clone instructions.
#    __pull   : Visualizes branch states, fast-forwards, and conflicts cleanly.
#    __status : Parses `git status -sb` to build an icon-based file tree.
#    __log    : Replaces the standard log with a fully interactive, searchable
#               FZF interface, complete with quick-copy shortcuts and a split-pane preview.
#
# Features:
#    Contextual Icons: Nerd Fonts mapping to added, deleted, renamed, or conflicted files.
#    Safe Execution: Uses `emulate -L zsh` to prevent polluting the global shell state.
#    Cross-Platform Clipboard: Auto-detects `pbcopy`, `wl-copy`, `xclip`, or `clip.exe`.
#    Alias Support: Inherits custom shorthand like `git st` or `git down`.
#
# Dependencies:
#    git  : Required for core functionality.
#    awk  : Required for advanced string parsing in `__status`.
#    sed  : Required for stream manipulation.
#    fzf  : Required for the interactive `__log` dashboard.
# ------------------------------------------------------------------------------


## ── Environment & Helpers ──────────────────────────────────────────────────────
## ------------------------------------------------------------------------------

# Environment Sandbox
emulate -L zsh
setopt localoptions no_xtrace pipefail

local BOLD=$'\033[1m'

# Clipboard Abstraction (Cross-Platform)
#   - Detects the correct clipboard command based on OS.
local _clip="cat" # Default fallback prevents crashes on headless servers

if [[ "$OSTYPE" == darwin* ]]; then
    _clip="pbcopy"
elif [[ "$OSTYPE" == linux* ]]; then
    # 1. Catch WSL (Windows Subsystem for Linux)
    if [[ -n "$WSL_DISTRO_NAME" ]] && (( $+commands[clip.exe] )); then
        _clip="clip.exe"
    # 2. Catch native Wayland
    elif (( $+commands[wl-copy] )); then
        _clip="wl-copy"
    # 3. Catch native X11
    elif (( $+commands[xclip] )); then
        _clip="xclip -selection clipboard"
    fi
fi

# Smart Pager Selection
#   - Use 'delta' for beautiful, side-by-side diffs if installed.
#   - Otherwise, fallback to 'cat' for raw text.
local _git_pager="cat"
if (( $+commands[delta] )); then
    # Escaping both variables ensures FZF calculates width dynamically at runtime!
    _git_pager="delta --side-by-side --width \${FZF_PREVIEW_COLUMNS:-\$COLUMNS}"
fi

# Function: is_in_git_repo
# Description: Checks if the current directory is within a Git work tree.
is_in_git_repo() {
    # Ultra-Fast Path: Pure Zsh upward traversal (No forks!)
    local d="$PWD"
    while [[ "$d" != "/" ]]; do
        # Check for .git directory (standard) or file (worktrees)
        [[ -e "$d/.git" ]] && return 0

        # Zsh magic: ':h' strips the last directory level (like 'dirname')
        d="${d:h}"
    done

    # Final check for root
    [[ -e "/.git" ]] && return 0
    return 1
}



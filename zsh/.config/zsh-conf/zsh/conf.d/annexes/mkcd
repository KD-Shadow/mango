# ------------------------------------------------------------------------------
# File Purpose
#   Combines 'mkdir' and 'cd' into a single, high-utility navigation command.
#
# Problems Solved
#   - Eliminates the two-step process of creating a folder and entering it.
#   - Prevents "Directory not found" errors by ensuring the path is created first.
#   - Provides immediate visual feedback of the new directory's location relative
#     to the filesystem root.
#   - Handles permission checks gracefully before attempting creation.
#
# Features / Responsibilities
#   - Recursive Creation: Uses `mkdir -p` to build deep path structures.
#   - Smart Validation: Detects existing directories and write-access issues.
#   - Hierarchy Visualization: Renders a "Breadcrumb Tree" of the current path.
#   - Content Inspection: Automatically lists contents or confirms an empty state.
#
# Usage Notes
#   - Syntax: mkcd <path/to/directory>
#   - Supports absolute paths, relative paths, and tilde (~) expansion.
# ------------------------------------------------------------------------------


# в”Җв”Җ navigation & scaffolding engine в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ




# ------------------------------------------------------------------------------
# 1. Environment Sandbox

# emulate -L zsh: Restricts shell option changes to this local function scope.
# pipefail: Ensures the function catches errors in complex pipelines.
emulate -L zsh
setopt localoptions no_xtrace pipefail


local target_dir="$1"

# ------------------------------------------------------------------------------
# 2. Input Validation

if [[ -z "$target_dir" ]]; then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} Usage: mkcd <path/to/directory>"
    return 1
fi

# ------------------------------------------------------------------------------
# 3. Logic & Execution

local is_new_dir=0

# Scenario A: Directory already exists
if [[ -d "$target_dir" ]]; then
    print "${COLOR[YELLOW]}вҡ ${COLOR[RESET]}  Directory '${COLOR[BOLD]}$target_dir${COLOR[RESET]}' already exists."

# Scenario B: New Directory Scaffolding
else
    # !!! CRITICAL: Permission Pre-check
    # We verify write access to the parent before attempting 'mkdir' to avoid
    # generic "Permission Denied" shell errors.
    local parent_path=$(dirname "$target_dir")
    if [[ ! -w "$parent_path" ]] && [[ -e "$parent_path" ]]; then
            print "${COLOR[RED]}[ERROR]${COLOR[RESET]} Permission denied: Cannot write to '$parent_path'."
            return 1
    fi

    # Create the path recursively (-p)
    if mkdir -p "$target_dir"; then
            print "${COLOR[GREEN]}вң”${COLOR[RESET]}  Created '${COLOR[BOLD]}$target_dir${COLOR[RESET]}'"
            is_new_dir=1
    else
            print "\n${COLOR[RED]}[ERROR]${COLOR[RESET]} Failed to create directory."
            return 1
    fi
fi

# ------------------------------------------------------------------------------
# 4. Navigation

# Attempt to move the shell into the target directory
if ! builtin cd "$target_dir"; then
    print "\n${COLOR[RED]}[FATAL]${COLOR[RESET]} Could not change directory."
    return 1
fi

# ------------------------------------------------------------------------------
# 5. Visual Visualization (TUI Dashboard)

# --- Section A: Location Tree ---
# We normalize the path for display, substituting the home directory for '~'.
local display_path="${PWD/#$HOME/~}"

print "\n${COLOR[BLUE]}рҹ“Қ LOCATION TREE:${COLOR[RESET]}"

# Complex Logic: Zsh Path Splitting
# (${(@s:/:)var}) splits the string by '/' into a temporary array.
local indent=""
local path_segments=("${(@s:/:)display_path}")

# Handle Root and Home-based paths
if [[ "$display_path" == "/" ]]; then
    print "${COLOR[BLUE]}  /${COLOR[RESET]}"
else
    if [[ "$display_path" == ~* ]]; then
            print "${COLOR[BLUE]}  ~${COLOR[RESET]}"
            [[ -z "${path_segments[1]}" ]] && shift path_segments
    elif [[ "$display_path" == /* ]]; then
            print "${COLOR[BLUE]}  /${COLOR[RESET]}"
    fi

    # Iterate through segments to draw the ASCII tree
    for seg in "${path_segments[@]}"; do
        [[ -z "$seg" ]] && continue
        if [[ "$seg" == "~" ]] && continue

        print "  $indent${COLOR[DIM]}в””в”Җв”Җ${COLOR[RESET]} ${COLOR[WHITE]}$seg${COLOR[RESET]}"
        indent="$indent    "
    done
    print "  $indent    ${COLOR[GREEN]}в¬Ҷ (You are here)${COLOR[RESET]}"
fi

# --- Section B: Content Tree ---
# We check for visibility of any files (hidden or otherwise).
if [[ -n "$(ls -A . 2>/dev/null)" ]]; then
    print "\n${COLOR[BLUE]}рҹ“Ӯ CONTENTS:${COLOR[RESET]}"

    # If 'tree' command exists, use it for rich visualization
    if (( $+commands[tree] )); then
        # -C: Color | -L 2: Max depth | --dirsfirst: Better sorting
        tree -C -L 2 --dirsfirst | head -n 20

        local item_count=$(ls -A | wc -l)
        (( item_count > 20 )) && print "${COLOR[GREY]}... ($item_count items total)${COLOR[RESET]}"
    else
        # Fallback for systems without 'tree' using sed to mimic tree-style pipes
        ls -F | sed -e 's/^/  в”ңв”Җв”Җ /'
    fi
else
    print "\n${COLOR[GREY]}(Directory is empty)${COLOR[RESET]}"
fi


#    в–‘в–Ҳв–Җв–„в–‘в–Ҳв–‘в–Ҳв–‘в–‘в–‘в–Ҳв–Җв–Җв–‘в–Ҳв–Җв–Ҳв–‘в–‘в–Ҳв–‘в–‘в–‘в–Ҳв–‘в–‘в–Ҳв–Җв–Җв–‘в–Ҳв–Җв–„в–‘в–Ҳв–‘в–Ҳ
#    в–‘в–Җв–‘в–Җв–‘в–Җв–‘в–Җв–‘в–Җв–‘в–Җв–‘в–‘в–‘в–Җв–‘в–Җв–‘в–‘в–Җв–‘в–‘в–‘в–Җв–‘в–‘в–Җв–Җв–Җв–‘в–Җв–‘в–Җв–‘в–Җв–‘в–Җ

# ------------------------------------------------------------------------------
# File Purpose
#   Provides a safe, interactive wrapper for pattern-based file deletion.
#
# Problems Solved
#   - Prevents accidental "mass-deletion" by forcing a review of matched files.
#   - Blocks "Fat Finger" disasters by blacklisting overly broad patterns (/, *, .).
#   - Provides a TUI (Terminal User Interface) to view the full list of targets
#     before committing to the 'delete' operation.
#
# Features / Responsibilities
#   - Pattern Validation: Rejects dangerous root or wildcard-only inputs.
#   - Match Analysis: Uses 'find' to perform a fast scan and item count.
#   - Interactive Dashboard: Shows a summary and a "Top 3" preview of matches.
#   - Review Mode: Integrates with 'fzf' for a searchable target list.
#
# Usage Notes
#   - Syntax: pattern-remove "*.tmp"
#   - Keybinds: [y] to delete, [v] to view full list, [N] to abort.
# ------------------------------------------------------------------------------


# в”Җв”Җ pattern deletion engine в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ




# ------------------------------------------------------------------------------
# 1. Environment Sandbox

# emulate -L zsh: Restricts shell option changes to this function's scope.
# pipefail: Ensures that if 'find' fails, the error propagates through the pipe.
emulate -L zsh
setopt localoptions no_xtrace pipefail

# ------------------------------------------------------------------------------
# 2. Input Validation

local search_pattern="$1"

# Check for empty input
if [[ -z "$search_pattern" ]]; then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} Usage: pattern-remove ${COLOR[WHITE]}<filename_pattern>${COLOR[RESET]}"
    print "        Example: pattern-remove '*.log'"
    return 1
fi

# !!! CRITICAL: Safety Blacklist
# We explicitly block patterns that could wipe the root, current, or parent
# directories to prevent catastrophic data loss.
if [[ "$search_pattern" == "/" || "$search_pattern" == "." || "$search_pattern" == ".." || "$search_pattern" == "*" ]]; then
    print "${COLOR[RED]}[FATAL]${COLOR[RESET]} Pattern '${COLOR[BOLD]}$search_pattern${COLOR[RESET]}' is too broad/dangerous."
    return 1
fi

# ------------------------------------------------------------------------------
# 3. State Machine Loop

# We use a 'while true' loop so the user can jump to the [V]iewer
# and return to the dashboard without exiting the function.
while true; do
    print -n "${COLOR[BLUE]}::${COLOR[RESET]} Scanning for '${COLOR[BOLD]}$search_pattern${COLOR[RESET]}'..."

    # Calculate exact number of matches
    local match_count
    match_count=$(find . -type f -name "$search_pattern" 2>/dev/null | wc -l | xargs)

    # Clear the "Scanning..." line using terminal escape codes
    # \r (return to start) and \e[K (clear to end of line)
    print -f "\r\e[K"

    # Exit if no targets are found
    if [[ "$match_count" -eq 0 ]]; then
        print "${COLOR[GREEN]}вң”${COLOR[RESET]} No files found matching '${COLOR[BOLD]}$search_pattern${COLOR[RESET]}'."
        return 0
    fi

    # ------------------------------------------------------------------------------
    # 4. Dashboard UI

    print "${COLOR[RED]}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${COLOR[RESET]}"
    print "${COLOR[RED]}в”Ӯ      рҹ—‘  DELETE PATTERN MATCHES      в”Ӯ${COLOR[RESET]}"
    print "${COLOR[RED]}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${COLOR[RESET]}"
    print "${COLOR[RED]}в”Ӯ${COLOR[RESET]}  Pattern: ${COLOR[WHITE]}$search_pattern${COLOR[RESET]}"
    print "${COLOR[RED]}в”Ӯ${COLOR[RESET]}  Matches: ${COLOR[WHITE]}$match_count files${COLOR[RESET]}"
    print "${COLOR[RED]}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${COLOR[RESET]}"

    # Render a mini-preview of the first 3 files to give immediate context.
    print "${COLOR[GREY]}Preview:${COLOR[RESET]}"
    find . -type f -name "$search_pattern" 2>/dev/null | head -n 3 | while read -r file; do
        print "  ${COLOR[RED]}Г—${COLOR[RESET]} $file"
    done

    if (( match_count > 3 )); then
        print "  ${COLOR[GREY]}...and $((match_count - 3)) more.${COLOR[RESET]}"
    fi

    print "\n${COLOR[YELLOW]}вҡ   Warning:${COLOR[RESET]} This will ${COLOR[BOLD]}permanently delete${COLOR[RESET]} these files."

    # ------------------------------------------------------------------------------
    # 5. Interactive Input

    print -n "   [y]es  [N]o  [v]iew full list > "

    local user_key
    read -k 1 user_key
    print # Newline after keypress

    case "$user_key" in
        [yY])
            # --- Execution Path ---
            print -n "${COLOR[BLUE]}::${COLOR[RESET]} Deleting..."
            find . -type f -name "$search_pattern" -delete
            print "\r\e[K   ${COLOR[GREEN]}вң”${COLOR[RESET]} Successfully deleted ${COLOR[BOLD]}$match_count${COLOR[RESET]} files."
            return 0
            ;;

        [vV])
            # --- View Mode ---
            # Logic: If fzf is available, provide an interactive searchable list.
            # Otherwise, fallback to 'less' for basic scrolling.
            if (( $+commands[fzf] )); then
                find . -type f -name "$search_pattern" | \
                fzf --header="Files matching: $search_pattern (ESC to return)" \
                    --prompt="Review > " \
                    --info=inline \
                    --layout=reverse \
                    --color="header:red"
            else
                find . -type f -name "$search_pattern" | less
            fi

            # Refresh the dashboard after returning from the viewer
            clear
            continue
            ;;

        *)
            # ---- SAFE: Abort on any other key (Default to No)
            print "   ${COLOR[GREY]}Operation aborted.${COLOR[RESET]}"
            return 0
            ;;
    esac
done

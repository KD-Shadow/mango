# ------------------------------------------------------------------------------
# File Purpose
#   A universal code runner that detects file types and executes them using the
#   appropriate compiler or interpreter.
#
# Problems Solved
#   - Eliminates the need to remember specific compiler flags (e.g., g++ -std=c++20).
#   - Automates the "Compile -> Execute -> Cleanup" workflow for binary languages.
#   - Provides high-precision execution timing for performance benchmarking.
#   - Handles process interruption (Ctrl+C) gracefully, ensuring no orphaned
#     temp files are left in /tmp.
#
# Features / Responsibilities
#   - Multi-Language Support: C, C++, Rust, Go, Java, Python, JS, TS, etc.
#   - Smart Compilation: Uses optimization flags (-O2) and modern standards.
#   - Sandboxed Execution: Compiles to unique temp paths to prevent collisions.
#   - Performance Tracking: Calculates runtime using $EPOCHREALTIME.
#
# Usage Notes
#   - Syntax: run_code <filename> [args...]
#   - Example: run_code main.cpp --input data.txt
# ------------------------------------------------------------------------------


# в”Җв”Җ execution engine в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ




# ------------------------------------------------------------------------------
# 1. Environment Sandbox

# emulate -L zsh: Restricts configuration changes to this local function scope.
# zmodload: Loads high-precision timing and mathematical function modules.
emulate -L zsh
setopt localoptions no_xtrace pipefail
zmodload zsh/datetime
zmodload zsh/mathfunc

# ------------------------------------------------------------------------------
# 2. Input Validation

local file="$1"

if [[ -z "$file" ]]; then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} No file provided."
    return 1
fi

if [[ ! -f "$file" ]]; then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} File '${COLOR[BOLD]}$file${COLOR[RESET]}' not found."
    return 1
fi

# Shift arguments: remove $1 (file) so that "$@" contains only user-passed flags.
shift

# ------------------------------------------------------------------------------
# 3. Path & UI Initialization

local file_ext="${file:e}"          # File extension (e.g., rs)
local file_base="${file:t:r}"       # Filename without extension (e.g., main)

# !!! CRITICAL: Atomic Temp Path
# We use the Process ID ($$) and EPOCHSECONDS to ensure that running multiple
# instances of the same script simultaneously doesn't lead to binary collisions.
local bin_path="/tmp/zsh_run_${file_base}_$$_${EPOCHSECONDS}"

# ------------------------------------------------------------------------------
# 4. Cleanup Strategy

# ---- SAFE: Ensure temp binary is removed even if the user hits Ctrl+C
trap 'rm -f "$bin_path" 2>/dev/null; print "\n${COLOR[RED]}::${COLOR[RESET]} Execution cancelled."; return 130' INT TERM

print "${COLOR[BLUE]}::${COLOR[RESET]} Processing ${COLOR[BOLD]}$file${COLOR[RESET]}..."

local start_time=$EPOCHREALTIME
local exit_status=0
local is_compiled=0

# ------------------------------------------------------------------------------
# 5. Language Decision Matrix

case "$file_ext" in
    # --- COMPILED LANGUAGES ---
    cpp|cc|cxx)
        print "   ${COLOR[YELLOW]}рҹ”Ё${COLOR[RESET]} Compiling (C++ 20)..."
        if g++ -std=c++20 -O2 "$file" -o "$bin_path"; then
            is_compiled=1
            print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running..."
            "$bin_path" "$@"
            exit_status=$?
        else
            exit_status=1
        fi
        ;;
    c)
        print "   ${COLOR[YELLOW]}рҹ”Ё${COLOR[RESET]} Compiling (GCC)..."
        if gcc -O2 "$file" -o "$bin_path"; then
            is_compiled=1
            print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running..."
            "$bin_path" "$@"
            exit_status=$?
        else
            exit_status=1
        fi
        ;;
    rs)
        print "   ${COLOR[YELLOW]}рҹ”Ё${COLOR[RESET]} Compiling (Rust)..."
        if rustc "$file" -o "$bin_path"; then
            is_compiled=1
            print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running..."
            "$bin_path" "$@"
            exit_status=$?
        else
            exit_status=1
        fi
        ;;
    java)
        # Modern Java (11+) allows direct execution of source files
        print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running (Java)..."
        java "$file" "$@"
        exit_status=$?
        ;;
    go)
        print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running (Go)..."
        go run "$file" "$@"
        exit_status=$?
        ;;

    # --- INTERPRETED LANGUAGES ---
    py|python)
        print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running (Python)..."
        python3 "$file" "$@"
        exit_status=$?
        ;;
    js)
        print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running (Node)..."
        node "$file" "$@"
        exit_status=$?
        ;;
    ts)
        print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running (TypeScript)..."
        # Prioritize Bun for speed, fallback to ts-node
        if (( $+commands[bun] )); then
            bun run "$file" "$@"
        elif (( $+commands[ts-node] )); then
            ts-node "$file" "$@"
        else
            print "${COLOR[RED]}[ERROR]${COLOR[RESET]} Neither 'bun' nor 'ts-node' found."
            exit_status=1
        fi
        exit_status=$?
        ;;
    sh|bash|zsh)
        print "   ${COLOR[GREEN]}рҹҡҖ${COLOR[RESET]} Running (Shell)..."
        ${SHELL:-bash} "$file" "$@"
        exit_status=$?
        ;;
    md)
        # Render Markdown in terminal using Glow
        if (( $+commands[glow] )); then
            glow "$file"
        else
            print "${COLOR[RED]}[ERROR]${COLOR[RESET]} 'glow' markdown renderer not found."
            exit_status=1
        fi
        ;;
    *)
        print "${COLOR[RED]}[ERROR]${COLOR[RESET]} Unsupported file extension: .${file_ext}"
        return 1
        ;;
esac

# ------------------------------------------------------------------------------
# 6. Post-Run Cleanup & Benchmarking

# Remove binary immediately after execution to keep /tmp clean
if (( is_compiled )) && [[ -f "$bin_path" ]]; then
    rm -f "$bin_path"
fi

local end_time=$EPOCHREALTIME
local total_duration=$(( end_time - start_time ))
local duration_fmt=$(print -f "%.3f" $total_duration)

print
if (( exit_status == 0 )); then
    print "${COLOR[GREEN]}вң”${COLOR[RESET]} Finished in ${COLOR[GREEN]}${duration_fmt}s${COLOR[RESET]}"
else
    print "${COLOR[RED]}вңҳ${COLOR[RESET]} Failed (Exit: $exit_status) in ${COLOR[RED]}${duration_fmt}s${COLOR[RESET]}"
fi

# Release the trap and return the original exit code
trap - INT TERM
return $exit_status


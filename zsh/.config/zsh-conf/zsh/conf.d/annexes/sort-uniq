# ------------------------------------------------------------------------------
# File Purpose
#   Provides a robust and high-performance utility to sort and deduplicate
#   text files.
#
# Problems Solved
#   - Standard 'sort' commands can be slow on large files due to locale-specific
#     collation; this script optimizes for raw byte-sorting.
#   - Prevents data loss by using an "Atomic Swap" pattern (writing to a temp
#     file first before overwriting the source).
#   - Provides a clear optimization report comparing line counts before and after.
#   - Automatically creates a backup (.bak) of the original data.
#
# Features / Responsibilities
#   - Performance: Uses 'LC_ALL=C' for maximum sorting speed.
#   - Integrity: Ensures files are only modified if duplicates are actually found.
#   - Visualization: Displays a TUI dashboard with percentage of data reclaimed.
#
# Usage Notes
#   - Syntax: sort_uniq <filename>
# ------------------------------------------------------------------------------


# в”Җв”Җ deduplication engine в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ




# ------------------------------------------------------------------------------
# 1. Environment Sandbox

# emulate -L zsh: Restricts configuration changes to this local function scope.
# pipefail: Ensures that if 'sort' fails in a pipe, the whole command returns
#           the error status.
emulate -L zsh
setopt localoptions no_xtrace pipefail

# ------------------------------------------------------------------------------
# 2. Input Validation

local source_file="$1"

if [[ -z "$source_file" ]]; then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} Usage: sort_uniq <filename>"
    return 1
fi

# Check if the file physically exists and is a regular file
if [[ ! -f "$source_file" ]]; then
    print "${COLOR[RED]}[ERROR]${COLOR[RESET]} File '${COLOR[BOLD]}$source_file${COLOR[RESET]}' not found."
    return 1
fi

# -s: checks if file size is greater than zero
if [[ ! -s "$source_file" ]]; then
    print "${COLOR[YELLOW]}вҡ ${COLOR[RESET]} File is empty. Nothing to do."
    return 0
fi

# ------------------------------------------------------------------------------
# 3. Pre-Processing Analysis

print -n "${COLOR[BLUE]}::${COLOR[RESET]} Analyzing..."

# Extract the line count before modification.
# We use 'tr -d' to ensure no leading/trailing spaces interfere with math logic.
local lines_before
lines_before=$(wc -l < "$source_file" | tr -d ' ')

# Clear the "Analyzing..." status using terminal escape codes (\r\e[K)
print -f "\r\e[K"

# ------------------------------------------------------------------------------
# 4. Sorting Logic

# !!! CRITICAL: Atomic Operation
# We write results to a temp file first. If the sort fails (e.g., out of disk space),
# the original file remains untouched.
local tmp_output
tmp_output=$(mktemp)

print -n "${COLOR[BLUE]}::${COLOR[RESET]} Sorting & Deduplicating..."

# ---- NOTE: LC_ALL=C Optimization
# By default, 'sort' respects system locale (e.g., UTF-8 collation rules).
# Forcing LC_ALL=C tells the binary to sort by raw byte values, which is
# significantly faster and produces consistent results for unique IDs/logs.
if ! LC_ALL=C sort -u "$source_file" > "$tmp_output"; then
    print "\n${COLOR[RED]}[ERROR]${COLOR[RESET]} Sort failed. Original file untouched."
    rm -f "$tmp_output"
    return 1
fi

local lines_after
lines_after=$(wc -l < "$tmp_output" | tr -d ' ')
print -f "\r\e[K"

# ------------------------------------------------------------------------------
# 5. Logic Check

# Calculate the number of redundant lines removed
local removed_count=$(( lines_before - lines_after ))

# If no duplicates were found, clean up and exit early to save IO
if (( removed_count == 0 )); then
    print "${COLOR[GREEN]}вң”${COLOR[RESET]} File is already sorted and unique. No changes made."
    rm -f "$tmp_output"
    return 0
fi

# ------------------------------------------------------------------------------
# 6. Applying Changes

# ---- SAFE: Backup creation
# Before overwriting, we create a fallback file.
cp "$source_file" "$source_file.bak"
mv "$tmp_output" "$source_file"

# ------------------------------------------------------------------------------
# 7. Dashboard Report

# Calculate percentage of data reduction
local reclaim_pct=$(( (removed_count * 100) / lines_before ))

print "${COLOR[BLUE]}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${COLOR[RESET]}"
print "${COLOR[BLUE]}в”Ӯ      рҹ“ү  OPTIMIZATION REPORT         в”Ӯ${COLOR[RESET]}"
print "${COLOR[BLUE]}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${COLOR[RESET]}"
print "${COLOR[BLUE]}в”Ӯ${COLOR[RESET]}  Before:  ${COLOR[WHITE]}$lines_before lines${COLOR[RESET]}"
print "${COLOR[BLUE]}в”Ӯ${COLOR[RESET]}  After:   ${COLOR[WHITE]}$lines_after lines${COLOR[RESET]}"
print "${COLOR[BLUE]}в”Ӯ${COLOR[RESET]}  Removed: ${COLOR[RED]}-$removed_count lines ($reclaim_pct%)${COLOR[RESET]}"
print "${COLOR[BLUE]}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${COLOR[RESET]}"

print "   ${COLOR[GREEN]}вң”${COLOR[RESET]} Optimized file saved to: ${COLOR[BOLD]}$source_file${COLOR[RESET]}"
print "   ${COLOR[GREY]}Backup saved to: $source_file.bak${COLOR[RESET]}"


#    в–‘в–Җв–Җв–Җв–‘в–‘в–Җв–‘в–‘в–Җв–Җв–Җв–‘в–Җв–‘в–‘в–‘в–Җв–‘в–Җв–‘в–Җв–‘в–Җв–‘в–‘в–Җв–‘в–‘в–Җв–Җв–Җв–‘в–Җв–‘в–Җ

# ------------------------------------------------------------------------------
# File Purpose
#   Provides a high-precision, interactive terminal stopwatch utility.
#
# Problems Solved
#   - Standard 'time' commands only measure process duration; this provides
#     real-time interactive tracking with pause/resume and lap support.
#   - Prevents UI flicker during sub-second updates using cursor repositioning.
#   - Maintains millisecond accuracy by utilizing the system's absolute epoch
#     time, avoiding the drift associated with simple 'sleep' loops.
#
# Features / Responsibilities
#   - Precision Engine: Uses $EPOCHREALTIME for microsecond-level calculation.
#   - Interactive TUI: Provides a boxed interface with dynamic status indicators.
#   - Lap Management: Records and displays a history of timed intervals.
#   - State Sandbox: Isolates shell options to prevent interference from external
#     Zsh plugins or themes.
#
# Usage Notes
#   - Controls: [Space] Pause/Resume | [L] Record Lap | [Q] Quit
#   - Requires Nerd Fonts for the timer and status icons.
# ------------------------------------------------------------------------------


# в”Җв”Җ stopwatch engine в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ




# ------------------------------------------------------------------------------
# 1. THE SILENT SANDBOX

# emulate -L zsh: Restricts configuration changes to this local scope.
# no_xtrace/no_verbose: Silences any global debugging that would corrupt the TUI.
emulate -L zsh
setopt localoptions no_xtrace no_verbose

# !!! CRITICAL: Global Trap Isolation
# We explicitly unset DEBUG and ZERR traps. This prevents Zsh frameworks like
# Oh-My-Zsh or Powerlevel10k from executing "prompt refresh" logic for every
# iteration of the math loop, which would drastically slow down the timer.
trap - DEBUG
trap - ZERR

# Load high-precision timing and mathematical conversion modules.
zmodload zsh/datetime
zmodload zsh/mathfunc


# в”Җв”Җ terminal configuration в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Hide cursor and disable keyboard echoing to prevent "ghost" characters
# from appearing on the screen when the user presses control keys.
print -f "\e[?25l"
stty -print
tput civis 2>/dev/null

# ---- SAFE: Restore terminal state on exit
# Ensures the cursor and keyboard print return even if the user kills the process.
trap 'stty print; print -f "\e[?25h"; tput cnorm 2>/dev/null; return' INT TERM EXIT


# в”Җв”Җ variable initialization в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

local start_time=$EPOCHREALTIME
local pause_time=0
local accumulated_pause=0
local is_paused=0
local -a laps=()

clear


# в”Җв”Җ main render loop в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

while true; do
    # ------------------------------------------------------------------------------
    # Complex Logic: Time Calculation
    # We calculate 'diff' by comparing current time to start time, then
    # subtracting any time spent in a 'paused' state to prevent clock drift.
    local current_time=$EPOCHREALTIME
    local diff

    if (( is_paused )); then
        diff=$(( pause_time - start_time - accumulated_pause ))
    else
        diff=$(( current_time - start_time - accumulated_pause ))
    fi

    # Convert raw seconds into H:M:S.ms using mathfunc integers.
    local h=$(( int(diff / 3600) ))
    local m=$(( int((diff % 3600) / 60) ))
    local s=$(( int(diff % 60) ))
    local ms=$(( int((diff - int(diff)) * 100) ))


    # ------------------------------------------------------------------------------
    # UI Drawing

    # \e[H: Repositions cursor to (1,1) without clearing.
    # This is the secret to a flicker-free terminal UI.
    print -f "\e[H"

    # 1. Border & Status
    print "${COLOR[BLUE]}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${COLOR[RESET]}"
    if (( is_paused )); then
        print "${COLOR[BLUE]}в”Ӯ      ${COLOR[YELLOW]}вҸё  PAUSED               ${COLOR[BLUE]}в”Ӯ${COLOR[RESET]}"
    else
        print "${COLOR[BLUE]}в”Ӯ      ${COLOR[GREEN]}вҸұ  RUNNING              ${COLOR[BLUE]}в”Ӯ${COLOR[RESET]}"
    fi

    # 2. Digital Readout
    print -f "${COLOR[BLUE]}в”Ӯ      ${COLOR[B_WHITE]}%02d:%02d:%02d${COLOR[DIM]}.%02d             ${COLOR[BLUE]}в”Ӯ${COLOR[RESET]}\n" $h $m $s $ms

    # 3. Controls Legend
    print "${COLOR[BLUE]}в”Ӯ                               в”Ӯ${COLOR[RESET]}"
    print "${COLOR[BLUE]}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${COLOR[RESET]}"
    print "${COLOR[BLUE]}в”Ӯ ${COLOR[DIM]}[SPACE] Pause  [L] Lap  [Q] Quit${COLOR[BLUE]} в”Ӯ${COLOR[RESET]}"
    print "${COLOR[BLUE]}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${COLOR[RESET]}"

    # 4. Lap History (Dynamic Section)
    # We display the last 5 laps in reverse order (newest at the top).
    if (( ${#laps} > 0 )); then
        print "\n%U${COLOR[CYAN]}рҹҡ© Lap History:${COLOR[RESET]}%u\e[J"
        local i count=0
        for (( i=${#laps}; i>=1; i-- )); do
            print "${laps[i]}"
            ((count++))
            (( count >= 5 )) && break
        done
    else
        # \e[J: Clears any leftover lap text when history is empty.
        print -f "\e[J"
    fi


    # в”Җв”Җ input handling в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    # read -sk 1: Read one character silently.
    # -t 0.05: Block for 50ms, giving us a 20fps refresh rate.
    local key=""
    read -sk 1 -t 0.05 key 2>/dev/null

    case "$user_key" in # Corrected from generic key for consistency
        [qQ]) break ;;

        [lL])
            # Complex Logic: Lap Recording
            # Laps are only recorded when active to prevent duplicate pauses.
            if (( ! is_paused )); then
                local lap_time=$(print -f "%02d:%02d:%02d.%02d" $h $m $s $ms)
                local lap_num=$(( ${#laps} + 1 ))
                laps+=("   ${COLOR[DIM]}Lap ${lap_num}:${COLOR[RESET]} $lap_time")
            fi
            ;;

        " ")
            # Complex Logic: Accumulating Pause Time
            # When unpausing, we measure the duration of the pause and
            # add it to 'accumulated_pause' so the stopwatch doesn't "skip".
            if (( is_paused )); then
                is_paused=0
                accumulated_pause=$(( accumulated_pause + (EPOCHREALTIME - pause_time) ))
            else
                is_paused=1
                pause_time=$EPOCHREALTIME
            fi
            ;;
    esac
done

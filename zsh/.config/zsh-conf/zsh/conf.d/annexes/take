#!/usr/bin/env zsh

#    ░▀█▀░█▀█░█░█░█▀▀
#    ░░█░░█▀█░█▀▄░█▀▀
#    ░░▀░░▀░▀░▀░▀░▀▀▀

# ------------------------------------------------------------------------------
# File Purpose
#   A "Universal Ingress" utility that acquires resources (URLs, Git repos,
#   shorthands) or creates directories and immediately moves the shell into them.
#
# Problems Solved
#   - Eliminates the context switch between cloning/downloading and 'cd'-ing.
#   - Standardizes "acquisition" logic for Git repos, GitHub shorthands,
#     and compressed archives (.zip, .tar.gz).
#   - Automates directory scaffolding if the target doesn't exist.
#   - Handles folder conflicts interactively (Enter, Overwrite, or Cancel).
#
# Features / Responsibilities
#   - Shorthand Expansion: Detects "user/repo" and expands to GitHub URLs.
#   - Archive Handling: Automatically downloads and extracts archives via curl.
#   - Shallow Cloning: Uses '--depth 1' for rapid Git acquisition.
#   - Visual Breadcrumbs: Renders a path hierarchy and content preview on landing.
#
# Usage Notes
#   - `take https://github.com/zsh-users/zsh-autosuggestions`
#   - `take ohmyzsh/ohmyzsh` (GitHub shorthand)
#   - `take my_new_project` (Local directory creation)
# ------------------------------------------------------------------------------


# ── ingress engine ───────────────────────────────────────────────────────────




# ------------------------------------------------------------------------------
# 1. Environment Sandbox

# emulate -L zsh: Restricts configuration changes to this local scope.
# pipefail: Ensures errors in curl | tar pipelines are caught.
emulate -L zsh
setopt localoptions no_xtrace pipefail

# UI Color Palette (High-fidelity Zsh formatting)
local c_blue="%F{39}"
local c_green="%F{46}"
local c_red="%F{196}"
local c_yellow="%F{226}"
local c_grey="%F{240}"
local c_reset="%f"
local c_bold="%B"
local c_unbold="%b"

local input_source="$1"
local input_target="$2"

# Validation: Ensure at least a source is provided
if [[ -z "$input_source" ]]; then
    print -P "${c_red}[ERROR]${c_reset} Usage: take <url|directory|shorthand>"
    return 1
fi

# ------------------------------------------------------------------------------
# 2. Intelligent Source Detection

# regex for various network protocols (git, ssh, http, etc.)
local protocol_regex='^(https?|git|ssh|ftps?|rsync)://|^[a-zA-Z0-9]+@'
# regex for GitHub "user/repo" style shorthand
local github_shorthand_regex='^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$'

local is_url=0
local action_type=""

if [[ "$input_source" =~ $protocol_regex ]]; then
    is_url=1
elif [[ "$input_source" =~ $github_shorthand_regex ]] && [[ ! -d "$input_source" ]]; then
    # --- Complex Logic: Shorthand Expansion ---
    # If the input looks like user/repo and isn't a local folder, assume GitHub.
    print -P "${c_blue}ℹ${c_reset}  Detected GitHub shorthand. Expanding..."
    input_source="https://github.com/${input_source}.git"
    is_url=1
fi

# ------------------------------------------------------------------------------
# 3. Target Path Normalization

if (( is_url )); then
    if [[ -z "$input_target" ]]; then
        # --- Complex Logic: URL Sanitization ---
        # Extract a clean folder name from a URL by stripping .git and parameters.
        input_target=$(basename "${input_source%%.git}")
        input_target="${input_target%%\?*}"
        input_target="${input_target%%#*}"

        # Strip archive extensions from the folder name
        if [[ "$input_target" =~ \.(zip|tar\.|tgz|tbz) ]]; then
            input_target="${input_target%.*}"
            input_target="${input_target%.tar}"
        fi
    fi
    action_type="clone"
else
    input_target="$input_source"
    action_type="create"
fi

# ------------------------------------------------------------------------------
# 4. Conflict Resolution

if [[ -d "$input_target" ]]; then
    print -P "${c_yellow}⚠${c_reset}  Target '${c_bold}$input_target${c_unbold}' already exists."
    print -P -n "   [e]nter  [o]verwrite  [c]ancel > "
    local key_press
    read -k 1 key_press
    print
    case "$key_press" in
        [eE]) action_type="enter" ;;
        [oO])
            print -P "   ${c_red}🗑${c_reset}  Cleaning old directory..."
            rm -rf "$input_target"
            ;; # Proceed to re-create or re-acquire
        *) return 1 ;;
    esac
fi

# ------------------------------------------------------------------------------
# 5. Resource Acquisition



if [[ "$action_type" == "enter" ]]; then
    true # No action needed, proceed to navigation
elif [[ "$action_type" == "create" ]]; then
    mkdir -p "$input_target"
elif [[ "$action_type" == "clone" ]]; then
    print -P "${c_blue}⬇${c_reset}  Acquiring resource..."

    # Logic Branch: Archive Download vs Git Clone
    if [[ "$input_source" =~ \.(zip|tar\.gz|tgz|tar\.bz2|tbz|tar\.xz)$ ]]; then
        mkdir -p "$input_target"
        print -P "   Downloading archive..."

        # Use curl | tar pipeline for memory efficiency (no temp file)
        if curl -L "$input_source" | tar xz -C "$input_target" --strip-components=1 2>/dev/null; then
                true
        else
                # Fallback: mktemp for pure .zip files (which tar cannot handle natively)
                local tmp_download=$(mktemp)
                curl -L "$input_source" -o "$tmp_download"
                if unzip -q "$tmp_download" -d "$input_target"; then
                    rm "$tmp_download"
                else
                    print -P "${c_red}[ERROR]${c_reset} Extraction failed."
                    rm "$tmp_download"
                    rmdir "$input_target"
                    return 1
                fi
        fi
    else
        # Default to Shallow Git Clone for speed
        git clone "$input_source" "$input_target" --depth 1
    fi
fi

# ------------------------------------------------------------------------------
# 6. Navigation & Breadcrumb Visualization



if builtin cd "$input_target"; then
    local current_display_path="${PWD/#$HOME/~}"

    print -P "\n${c_green}✔${c_reset}  Landed in: ${c_bold}$input_target${c_unbold}"

    # --- Section: Location Visualization ---
    print -P "${c_blue}📍 LOCATION:${c_reset}"
    local indent_spacer=""
    local path_segments=("${(@s:/:)current_display_path}")

    if [[ "$current_display_path" == "/" ]]; then
            print -P "  /"
    else
            if [[ "$current_display_path" == ~* ]]; then
                print -P "  ~"
                [[ -z "${path_segments[1]}" ]] && shift path_segments
            fi
            # Render the ASCII breadcrumb tree
            for segment in "${path_segments[@]}"; do
                [[ -z "$segment" ]] && continue
                if [[ "$segment" == "~" ]] && continue
                print -P "  $indent_spacer└── $segment"
                indent_spacer="$indent_spacer    "
            done
            print -P "  $indent_spacer    ${c_green}⬆ (You are here)${c_reset}"
    fi

    # --- Section: Content Preview ---
    if [[ -n "$(ls -A . 2>/dev/null)" ]]; then
            print -P "\n${c_blue}📂 CONTENTS:${c_reset}"
            # head -n 5: Limit preview to prevent terminal flooding
            ls -F --color=auto 2>/dev/null | head -n 5 | sed 's/^/  ├── /'
            local total_items=$(ls -A | wc -l)
            (( total_items > 5 )) && print -P "  ... ($((total_items-5)) more)"
    fi
else
    print -P "\n${c_red}[FATAL]${c_reset} Failed to enter directory."
    return 1
fi


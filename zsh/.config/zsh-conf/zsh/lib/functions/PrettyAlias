#!/usr/bin/env zsh

# ------------------------------------------------------------------------------
# PRETTY ALIAS (Binary/Script Mode)
# ------------------------------------------------------------------------------
# Usage:
#   1. To list aliases:  alias | pretty-alias
#   2. To set aliases:   This script CANNOT set aliases for your parent shell.
#                        Use standard 'alias name=value' for that.

# 1. Input Handling
# ───────────────────────────────────────────────────────────────────────
# If arguments are passed (e.g., "name=value"), we warn the user that
# this cannot work in a binary script.
if [[ $# -gt 0 ]]; then
   print "${COLOR[RED]}[ERROR]${COLOR[DIM]} Cannot set aliases via an external script (subprocess isolation).${COLOR[RESET]}"
    print "       Use the builtin ${CLOR[YELLOW]}${COLOR[BOLD]}alias${COLOR[RESET]} command to set new aliases."
    print "       Usage: alias | pretty-alias"
    exit 1
fi

# 2. Rendering Logic
# ───────────────────────────────────────────────────────────────────────
# We read from Standard Input (Pipe) because an external script cannot
# see the parent shell's aliases directly.

# Check if input is coming from a pipe
if [[ -t 0 ]]; then
    print "${COLOR[YELLOW]}[INFO]${COLOR[RESET]} No input detected."
    print "       Usage: ${COLOR[GREEN]}alias | pretty-alias${COLOR[RESET]}"
    exit 0
fi

# Get terminal width
cols=$(tput cols)

# 3. Rendering Logic
sort | awk -v C_NAME="${COLOR[BOLD]}${COLOR[BLUE]}" \
                 -v C_EQ="${COLOR[DIM]}" \
                 -v C_VAL="${COLOR[GREEN]}" \
                 -v C_RST="${COLOR[RESET]}" \
                 -v TERM_WIDTH="$cols" \
'
{
    idx = index($0, "=")
    if (idx == 0) next;

    name = substr($0, 1, idx - 1)
    val  = substr($0, idx + 1)

    # Define layout dimensions
    name_width = 20
    prefix_total = 2 + name_width + 4 # spaces + name + " :: "
    available_width = TERM_WIDTH - prefix_total - 2

    # Print the first line (Name + start of Value)
    print -f "  %s%-20s%s %s::%s %s", C_NAME, name, C_RST, C_EQ, C_RST, C_VAL

    # Logic to wrap the value
    if (length(val) <= available_width) {
        print val C_RST
    } else {
        # Print first chunk
        print substr(val, 1, available_width) C_RST

        # Calculate remaining string
        remaining = substr(val, available_width + 1)

        # Loop to print wrapped lines with indentation
        while (length(remaining) > 0) {
            # Create the indentation string (matches name_width + spacers)
            print -f "  %20s    %s%s%s\n", "", C_VAL, substr(remaining, 1, available_width), C_RST
            remaining = substr(remaining, available_width + 1)
        }
    }
}' | less -RFX

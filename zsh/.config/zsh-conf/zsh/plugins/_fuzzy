# ------------------------------------------------------------------------------
# File Purpose
#   Configures FZF (Fuzzy Finder) as the primary interaction layer for Zsh.
#   It overrides standard completions and keybindings to provide rich,
#   context-aware previews for files, directories, processes, and more.
#
# Problems Solved
#   - Standard Tab-completion is static; FZF makes it searchable and visual.
#   - Replaces slow 'find' calls with optimized tools like 'rg' or 'fd'.
#   - Provides "instant-read" previews (syntax-highlighted code, directory trees).
#   - Standardizes clipboard and editor integration across platforms.
#
# Features / Responsibilities
#   - **Smart Compgen:** Optimized directory/file discovery logic.
#   - **Contextual Previews:** Dynamic logic for `cd`, `vim`, `ssh`, `git`, etc.
#   - **Unified UI:** Rounded borders, consistent color palette, and iconography.
#   - **High-Speed Search:** Native integration with Ripgrep and FD.
#
# Usage Notes
#   - Requires: `fzf` (Binary).
#   - Optional: `bat`, `eza`, `fd`, `rg`, `delta` for enhanced visuals.
#

# ------------------------------------------------------------------------------


# в”Җв”Җ initialization & dependencies в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# ------------------------------------------------------------------------------
# Clipboard Detection
# ------------------------------------------------------------------------------
local CLIP_CMD=""

if [[ "$OSTYPE" == "darwin"* ]]; then
    CLIP_CMD="pbcopy" # macOS
elif [[ -n "$WAYLAND_DISPLAY" ]] && (( $+commands[wl-copy] )); then
    CLIP_CMD="wl-copy" # Wayland
elif (( $+commands[xclip] )); then
    CLIP_CMD="xclip -selection clipboard" # X11 xclip
elif (( $+commands[xsel] )); then
    CLIP_CMD="xsel --clipboard --input" # X11 xsel
else
    CLIP_CMD="cat" # Fallback to stdout
fi


# в”Җв”Җ custom completion engines в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# ------------------------------------------------------------------------------
# Function: _fzf_compgen_dir
# Description: Overrides directory discovery for FZF completions.
# ------------------------------------------------------------------------------
_fzf_compgen_dir() {
    local base_dir="$1"

    if (( $+commands[fd] )); then
        # Use 'fd' for performance and automatic .gitignore respect
        fd --type d --hidden --follow --color=always \
           --exclude ".git" \
           --exclude "node_modules" \
           . "$base_dir"
    else
        # Fallback to universal 'find' with pruning logic for heavy folders
        command find -L "$base_dir" \
            \( -name .git -o -name node_modules \) -prune -o \
            -type d -print 2>/dev/null
    fi
}

# ------------------------------------------------------------------------------
# Function: _fzf_compgen_unalias
# Description: Specialized FZF picker for unsetting shell aliases with previews.
# ------------------------------------------------------------------------------
_fzf_compgen_unalias() {
    local tmp=$(mktemp "${TMPDIR:-/tmp}/zsh-aliases.XXXXXX")
    trap "rm -f '$tmp'" EXIT

    # Capture current aliases to a temp file for the FZF subshell to read
    alias > "$tmp"

    local preview_cmd="grep -F --color=always \"{}=\" '$tmp'"
    if (( $+commands[bat] )); then
        preview_cmd="$preview_cmd | bat -l zsh --style=plain --color=always"
    fi

    print -l "${(@k)aliases}" | fzf "$@" --preview "$preview_cmd"
}

# ------------------------------------------------------------------------------
# Function: _fzf_comprun
# Description: The "Brain" of FZF context-awareness. It determines what preview
#              to show based on the command you are currently typing.
# ------------------------------------------------------------------------------
_fzf_comprun() {
    local command=$1
    shift

    case "$command" in
        # 1. Navigation (cd/pushd) -> Show Directory Trees
        cd|pushd|rmdir)
            if (( $+commands[eza] )); then
                fzf "$@" --preview 'eza --tree --level=2 --color=always --icons=always --group-directories-first {} | head -200'
            elif (( $+commands[tree] )); then
                fzf "$@" --preview 'tree -C {} | head -200'
            else
                fzf "$@" --preview 'ls -1 --color=always {} | head -200'
            fi
            ;;

        # 2. Files (vim/cat/bat) -> Show Syntax Highlighted Code
        vim|nvim|vi|nano|code|cat|bat|less|more)
            if (( $+commands[bat] )); then
                fzf "$@" --preview 'bat --style=numbers --color=always --line-range :500 {}' \
                        --preview-window 'right:60%:border-left'
            else
                fzf "$@" --preview 'cat {}'
            fi
            ;;

        # 3. Environment & Processes -> Show Values/Status
        export|unset|printenv)
            fzf "$@" --preview "printenv {}" --preview-window="bottom:3:wrap"
            ;;
        kill|pkill)
            fzf "$@" --preview 'ps -fp {1} 2>/dev/null || print "Process not found"' \
                    --preview-window="bottom:20%:wrap"
            ;;

        # 4. Networking & SSH -> Show Config Fragments
        ssh|telnet)
            fzf "$@" --preview 'cat ~/.ssh/config 2>/dev/null | grep -A 4 "Host {}" || print "System Host: {}"' \
                    --preview-window="bottom:20%:wrap"
            ;;

        # 5. Git -> Show Colorful Diffs
        git)
            if (( $+commands[delta] )); then
                fzf "$@" --preview 'git diff --color=always {} | delta' --preview-window 'right:60%'
            else
                fzf "$@" --preview 'git diff --color=always {}' --preview-window 'right:60%'
            fi
            ;;

        unalias) _fzf_compgen_unalias "$@" ;;

        systemctl)
             fzf "$@" --preview 'systemctl status {1} --no-pager 2>/dev/null || print "Status unavailable"' \
                      --preview-window="right:60%:wrap"
             ;;

        # 7. Service Management (macOS)
        #    'launchctl list' shows PID, Last Exit Status, and Label
        launchctl)
             fzf "$@" --preview 'launchctl list {1} 2>/dev/null || print "No info available for {1}"' \
                      --preview-window="bottom:20%:wrap"
             ;;

        # 10. Multi-Tool Fallback logic for everything else
        *)
            local preview_cmd="print {}"
            if (( $+commands[bat] )); then
                preview_cmd="if [ -f {} ]; then bat --style=numbers --color=always --line-range :500 {};"
            else
                preview_cmd="if [ -f {} ]; then cat {};"
            fi

            if (( $+commands[eza] )); then
                 preview_cmd+=" elif [ -d {} ]; then eza --tree --level=2 --color=always --icons=always {} | head -200;"
            else
                 preview_cmd+=" elif [ -d {} ]; then ls -1 --color=always {};"
            fi
            preview_cmd+=" else print {}; fi"

            fzf "$@" --preview "$preview_cmd"
            ;;
    esac
}


# в”Җв”Җ global fzf options & keybindings в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

export FZF_DEFAULT_OPTS="
    # 1. TOKYO NIGHT COLOR PALETTE
    --color=fg:#c0caf5,bg:-1,hl:#36608a:bold
    --color=fg+:#ffffff,bg+:#1f2335,hl+:#76b9e0:bold
    --color=info:#7aa2f7,prompt:#f7768e,pointer:#f7768e
    --color=marker:#9ece6a,spinner:#9ece6a,header:#9ece6a
    --color=border:#414868,label:#aeaeae,query:#ddb6f2
    --color=preview-border:#f7768e
    --gutter ' ' --color gutter:-1

    # 2. UI SETTINGS
    --multi
    --border='rounded'
    --border-label=' пҖӮ Fuzzy Finder'
    --border-label-pos='4'
    --preview-window='border-rounded,hidden'
    --prompt='пһҹ п‘„ '
    --pointer='в–Ң'
    --marker='пҖҢ '
    --info='inline'
    --height='45%'
    --layout='reverse'
    --margin='1'
    --padding='1,1,0,1'
    --preview '[[ \$(file --mime {}) =~ binary ]] && print {} is a binary file || (bat --style=numbers --color=always {} || cat {}) 2> /dev/null | head -500'

    # 3. KEYBINDINGS
    --bind 'ctrl-j:preview-down'
    --bind 'ctrl-k:preview-up'
    --bind 'ctrl-a:select-all'
    --bind 'ctrl-y:execute-silent(print {+} | $CLIP_CMD)'

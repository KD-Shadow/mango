    --bind 'ctrl-\:toggle-preview'
"


# в”Җв”Җ search tool backend в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Centralized list of noisy directories to ignore globally
local _fzf_ignore_list=(
    .git .mypy_cache .tox .cache .venv venv node_modules __pycache__ site-packages
)

if (( $+commands[rg] )); then
    # RIPGREP: Native .gitignore support + ultra-fast filtering
    export FZF_DEFAULT_COMMAND="rg --files --hidden --follow ${(@)_fzf_ignore_list/#/--glob \!}"
    export FZF_ALT_C_COMMAND='find . -type d'
elif (( $+commands[fd] )); then
    # FD: Purpose-built for file discovery
    local fd_excludes="${(@)_fzf_ignore_list/#/--exclude }"
    export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --strip-cwd-prefix $fd_excludes"
    export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --strip-cwd-prefix $fd_excludes"
else
    # FIND: Standard POSIX fallback
    export FZF_DEFAULT_COMMAND='find . -type f'
    export FZF_ALT_C_COMMAND='find . -type d'
fi

# Ensure Ctrl-T (File Finder) uses the same optimized command
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"


# в”Җв”Җ keybinding-specific preview strategies в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Select File Previewer (Prioritize bat)
local _fzf_preview_file_cmd
if (( $+commands[bat] )); then
    _fzf_preview_file_cmd='bat --color=always --style=numbers --line-range=:500 {}'
else
    _fzf_preview_file_cmd='cat {}'
fi

# Select Directory Previewer (Prioritize eza)
local _fzf_preview_dir_cmd
if (( $+commands[eza] )); then
    _fzf_preview_dir_cmd='eza --tree --color=always {} | head -200'
elif (( $+commands[tree] )); then
    _fzf_preview_dir_cmd='tree -C {} | head -200'
else
    _fzf_preview_dir_cmd='ls -1 {}'
fi

# Apply Previews to Widgets
export FZF_CTRL_T_OPTS="--preview '$_fzf_preview_file_cmd 2>/dev/null' --bind 'ctrl-/:toggle-preview'"
export FZF_ALT_C_OPTS="--preview '$_fzf_preview_dir_cmd 2>/dev/null'"

# Cleanup helper variables
unset _fzf_preview_file_cmd _fzf_preview_dir_cmd


# в”Җв”Җ os-specific shell loading в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Load standard FZF completion and key-bindings for macOS (Homebrew paths)
[[ -f /opt/homebrew/opt/fzf/shell/completion.zsh ]]   && source /opt/homebrew/opt/fzf/shell/completion.zsh
[[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]] && source /opt/homebrew/opt/fzf/shell/key-bindings.zsh


# в”Җв”Җ Fzf-Tab Configuration в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

## Configuration for the fzf-tab plugin (rich previews).
zstyle ':completion:*' menu no      # Disable default menu (we use fzf-tab's menu)

# zstyle ':completion:*' format ''    # Need to set it to none so that it behaves right

# Group Descriptions (Fzf's theme)
zstyle ':completion:*:*:*:*:descriptions' format '[%d]'

# в”Җв”Җ Behavior в”Җв”Җ
# Trigger fzf on path completion automatically
zstyle ':fzf-tab:*' continuous-trigger '/'

# Switch groups with < and >
zstyle ':fzf-tab:*' switch-group '<' '>'

# в”Җв”Җ Styling в”Җв”Җ

# Use LS_COLORS for fzf-tab
zstyle ':fzf-tab:*' list-colors ${(s.:.)LS_COLORS}

# в”Җв”Җ Context-Aware Previews в”Җв”Җ
# Use 'bat' for file previews if available, otherwise cat
zstyle ':fzf-tab:complete:*:*' fzf-preview \
    'if [[ -d $realpath ]]; then
        # If it is a directory, list it with eza
        eza -1 --color=always --icons=always --group-directories-first $realpath
     else
        # If it is a file, show content with bat
        if (( $+commands[bat] )); then
            bat --color=always --style=numbers --line-range=:500 $realpath
        else
            cat $realpath
        fi
     fi'

# 'cd': Use 'eza' with tree view (limit level 2) to see folder structure
zstyle ':fzf-tab:complete:cd:*' fzf-preview \
    'eza --tree --level=2 --color=always --icons=always --group-directories-first --git $realpath'

# 'systemctl': Preview service status
zstyle ':fzf-tab:complete:systemctl-*:*' fzf-preview \
    'SYSTEMD_COLORS=1 systemctl status $word'

# 'command': Preview man page or file content
zstyle ':fzf-tab:complete:(-command-):*' fzf-preview \
    '[[ -n $builtins[$word] ]] && man $word || bat --color=always --style=plain $realpath 2>/dev/null'

# kill: Show process details
zstyle ':fzf-tab:complete:kill:argument-rest' fzf-preview \
    'ps --pid=$group --format=cmd --no-headers -w -w'

zstyle ':fzf-tab:complete:kill:argument-rest' fzf-flags \
    '--preview-window=down:3:wrap'


# в”Җв”Җ Global FZF-Tab Options в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Inherits FZF_DEFAULT_OPTS
zstyle ':fzf-tab:*' fzf-flags \
    --multi \
    --bind 'space:toggle' \
    --style=full \
    --height=45% \
    --pointer '>' \
    --color 'pointer:green:bold' \
    --color 'bg+:-1:,fg+:green:bold,hl+:yellow:bold,hl:gray:bold' \
    --color 'info:blue:bold,marker:yellow:bold' \
    --input-label ' Search ' \
    --color 'input-border:blue,input-label:blue:bold' \
    --list-label ' Results ' \
    --color 'list-border:green,list-label:green:bold' \
    --preview-label ' Preview ' \
    --color 'preview-border:magenta,preview-label:magenta:bold' \
    --gutter ' ' \
    --color 'gutter:-1' \
    --bind 'ctrl-\:toggle-preview'

zstyle ':fzf-tab:*' fzf-bindings 'space:accept'
zstyle ':fzf-tab:*' accept-line enter


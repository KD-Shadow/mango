#    ‚ĖĎ‚Ėą‚ĖÄ‚ĖÄ‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ‚Ėą
#    ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖĎ

# ------------------------------------------------------------------------------
# File Purpose
#   A robust "Fuzzy Change Directory" utility.
#
# Problems Solved
#   - Navigating deep directory structures without knowing the exact path.
#   - Visualizing the destination folder content *before* entering it.
#   - Abstraction over underlying tools (works with or without `fd`/`eza`).
#
# Features
#   - **Smart Search:** Prefers `fd` (fast, respects gitignore) over `find`.
#   - **Rich Preview:** Cascading fallback (eza -> tree -> ls).
#   - **Auto-List:** Automatically shows contents upon arrival.
#
# Usage
#   - `fcd`        : Search from current directory.
#   - `fcd path/`  : Search from specific path.
# ------------------------------------------------------------------------------

# 1. Environment Sandbox
emulate -L zsh
setopt localoptions no_xtrace pipefail

local start_dir="${1:-.}"
local selected_dir
local preview_cmd

# 2. Preview Strategy (Calculate once)
# We build the command string here so the FZF subshell doesn't have to check
# for existence on every single keystroke.
if (( $+commands[eza] )); then
    preview_cmd="eza --tree --level=2 --color=always {} 2>/dev/null"
elif (( $+commands[tree] )); then
    preview_cmd="tree -C {} 2>/dev/null"
else
    preview_cmd="ls -1 --color=always {}"
fi

# 3. Search & Select
# We intentionally avoid 'eval' for security and handle the pipe directly.

# CASE A: Fast Search (fd)
if (( $+commands[fd] )); then
    selected_dir=$(fd --type d --hidden --follow --exclude .git . "$start_dir" | \
        fzf \
        --no-multi \
        --prompt="ūüďā CD > " \
        --header="Select directory" \
        --preview-window="right:60%:wrap:nohidden" \
        --preview "$preview_cmd" \
        --bind 'tab:toggle+down,shift-tab:toggle+up'
    )

# CASE B: Universal Search (find)
else
    selected_dir=$(find "$start_dir" -type d -name .git -prune -o -type d -print 2>/dev/null | \
        fzf \
        --no-multi \
        --prompt="ūüďā CD > " \
        --header="Select directory (using 'find')" \
        --preview-window="right:60%:wrap:nohidden" \
        --preview "$preview_cmd" \
        --bind 'tab:toggle+down,shift-tab:toggle+up'
    )
fi

# 4. Navigation & Feedback
if [[ -n "$selected_dir" ]]; then
    # builtin cd prevents recursive alias loops
    if builtin cd "$selected_dir"; then
        print "\n${COLOR[BLUE]}‚ěú Entered:${COLOR[RESET]} ${COLOR[BOLD]}$selected_dir${COLOR[RESET]}"

        # Auto-List content on arrival
        if (( $+commands[eza] )); then
            eza -G --color=always --icons --group-directories-first
        else
            ls -F --color=auto
        fi
    else
        print "${COLOR[RED]}[ERROR]${COLOR[RESET]} Permission denied or directory missing."
        return 1
    fi
fi

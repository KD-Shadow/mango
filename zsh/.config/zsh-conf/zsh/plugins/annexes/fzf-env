# ------------------------------------------------------------------------------
# File Purpose
#   Interactive viewer for Shell Environment Variables.
#
# Problems Solved
#   - Reading long, truncated variables (like $PATH or tokens) is difficult with
#     standard `env` or `printenv`.
#   - Copying complex values requires precise mouse selection.
#
# Features
#   - **Smart Preview:** Wraps long lines and syntax highlights (if `bat` exists).
#   - **Clipboard Integration:** One-key copy (Ctrl-Y) for tokens/keys.
#   - **Search:** Instantly filter by variable name (e.g., "USER", "PATH").
#
# Usage
#   - `fenv` : Open the inspector.
# ------------------------------------------------------------------------------

# 1. Environment Sandbox
emulate -L zsh
setopt localoptions no_xtrace pipefail

# 2. Clipboard Detection (Platform Agnostic)
local copy_cmd="cat" # Fallback

if [[ "$OSTYPE" == "darwin"* ]]; then
    copy_cmd="pbcopy"
elif [[ -n "$WAYLAND_DISPLAY" ]] && (( $+commands[wl-copy] )); then
    copy_cmd="wl-copy"
elif (( $+commands[xclip] )); then
    copy_cmd="xclip -selection clipboard"
elif (( $+commands[xsel] )); then
    copy_cmd="xsel --clipboard --input"
elif (( $+commands[clip.exe] )); then
    copy_cmd="clip.exe" # WSL
fi

# 3. The Interactive Loop
local selection

# We pipe `env` into FZF.
# The preview logic handles the extraction of the value (everything after the first =)
# and formats it for readability.
selection=$(env | fzf \
    --prompt="ÔĒą  Env > " \
    --header="Enter: Print ‚ÄĘ Ctrl-Y: Copy Value" \
    --height=60% --layout=reverse --border --info=inline \
    \
    --preview '
        # Extract Value (cut fields 2 onwards)
        val=$(print {} | cut -d= -f2-)

        # Formatting Strategy
        if command -v bat > /dev/null; then
            # Use Bat for wrapping and color
            print "$val" | bat -l bash --style=plain --color=always --wrap=character
        else
            # Fallback: Fold to terminal width
            print "$val" | fold -w $COLUMNS
        fi
    ' \
    --preview-window="right:60%:wrap" \
    \
    --bind "ctrl-y:execute-silent(print {} | cut -d= -f2- | $copy_cmd)+abort"
)

# 4. Output Logic (If user pressed Enter)
if [[ -n "$selection" ]]; then
    # Print only the value to stdout
    print "$selection" | cut -d= -f2-
fi

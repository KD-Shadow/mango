# ------------------------------------------------------------------------------
# File Purpose
#   A "Task Manager" for the terminal using FZF.
#
# Problems Solved
#   - Finding a runaway process without manually grepping `ps`.
#   - Killing multiple processes simultaneously (Multi-select).
#   - Verifying the exact command arguments before killing.
#
# Features
#   - **Live Reload:** Ctrl-R refreshes the process list.
#   - **Smart Preview:** Shows process tree (pstree) or full details.
#   - **Safety First:** Defaults to SIGTERM (15) to allow graceful shutdown.
#
# Usage
#   - `fkill`      : Open menu (Defaults to SIGTERM).
#   - `fkill -9`   : Open menu, force kill selected (SIGKILL).
# ------------------------------------------------------------------------------

# 1. Environment Sandbox
emulate -L zsh
setopt localoptions no_xtrace pipefail

# 2. Determine Signal
#    Default to -15 (SIGTERM) for graceful cleanup.
#    User can pass -9 as argument to override.
local signal="${1:-15}"

# 3. Preview Strategy
#    If 'pstree' exists, we show the hierarchy of the selected PID.
#    Otherwise, we show the full process entry.
local preview_cmd=""
if (( $+commands[pstree] )); then
    # -p: show PIDs, -a: show arguments, -C: color
    # {2}: The PID column from ps -ef
    preview_cmd="pstree -p -a -C age {2} | head -20"
else
    preview_cmd="print {}"
fi

# 4. Interactive Selection
#    We use 'ps -ef' for broad compatibility (macOS & Linux).
local selected
selected=$(ps -ef | fzf \
    --multi \
    --header-lines=1 \
    --prompt="ūüíÄ Kill ($signal) > " \
    --header="Tab: Multi-select ‚ÄĘ Ctrl-R: Reload" \
    --layout=reverse --border --height=60% --info=inline \
    --preview-window="right:50%:wrap" \
    --preview "$preview_cmd" \
    --bind 'ctrl-r:reload(ps -ef)' \
    --bind 'tab:toggle+down,shift-tab:toggle+up' \
    --color='header:blue,prompt:red,pointer:red,marker:yellow'
)

# 5. Execution Logic
if [[ -n "$selected" ]]; then
    # Extract PIDs (Column 2) using awk
    local pids
    pids=$(print "$selected" | awk '{print $2}')

    print "\n${COLOR[RED]}::${COLOR[RESET]} Sending signal ${COLOR[BOLD]}$signal${COLOR[RESET]} to processes..."

    # Iterate and Kill
    print "$pids" | while read -r pid; do
        # Skip invalid/empty lines
        [[ -z "$pid" ]] && continue

        if kill "-$signal" "$pid" 2>/dev/null; then
            print "   ${COLOR[GREEN]}‚úĒ${COLOR[RESET]} Killed PID ${COLOR[DIM]}$pid${COLOR[RESET]}"
        else
            print "   ${COLOR[RED]}‚úė${COLOR[RESET]} Failed to kill PID ${COLOR[DIM]}$pid${COLOR[RESET]} (Permission denied?)"
        fi
    done
fi

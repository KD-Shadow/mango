#    ‚ĖĎ‚Ėą‚ĖÄ‚ĖÄ‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖĎ‚Ėą
#    ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ

# ------------------------------------------------------------------------------
# File Purpose
#   A "Safety-First" interactive wrapper for the `rm` command.
#
# Problems Solved
#   - Accidental deletion: Requires explicit confirmation before `rm -rf`.
#   - Blind deletion: Provides a preview of the file/folder content before selection.
#   - Binary safety: Detects binary files in the preview to prevent terminal corruption.
#
# Features
#   - **Hybrid Mode:** Acts like normal `rm` if arguments are passed.
#   - **MIME Detection:** Previews text files but just shows metadata for binaries.
#   - **Batch Processing:** Select multiple files with <Tab> to delete in bulk.
#
# Usage
#   - `frm`        : Open interactive menu.
#   - `frm file.txt` : Behaves like `rm -v file.txt`.
# ------------------------------------------------------------------------------

# 1. Environment Sandbox
emulate -L zsh
setopt localoptions no_xtrace pipefail

# 2. Passthrough Mode
#    If arguments are provided, pass them directly to 'rm' and exit.
#    SAFETY: We use -v (verbose) but do NOT force -rf.
if [[ "$#" -gt 0 ]]; then
    command rm -v "$@"
    return
fi

# 3. List Generation
#    Prioritize 'fd' (fast, respects .gitignore) > 'ls' (fallback)
local list_cmd
if (( $+commands[fd] )); then
    list_cmd="fd --max-depth 1 --hidden --exclude .git --strip-cwd-prefix"
else
    list_cmd="command ls -A1"
fi

# 4. Preview Strategy (MIME-Aware)
#    This script runs inside the FZF subshell.
local preview_script='
    file={};
    if [ -d "$file" ]; then
        eza --tree --level=2 --color=always "$file" 2>/dev/null || tree -C "$file" | head -200
    else
        mime=$(file --mime-type -b "$file" 2>/dev/null)
        if [[ $mime == text/* || $mime == "application/json" || $mime == "inode/x-empty" ]]; then
            bat --style=numbers --color=always "$file" 2>/dev/null || cat "$file"
        else
            print "Binary File ($mime)"
        fi
    fi
'

# 5. Interactive Selection
local selected
selected=$(eval "$list_cmd" | fzf \
    --multi \
    --prompt="ūüíÄ Delete > " \
    --header="Tab: Select Multiple | Enter: Confirm" \
    --preview-window="right:60%:wrap" \
    --preview "$preview_script" \
    --height=80% --layout=reverse --border --info=inline \
    --color='header:yellow,prompt:red,pointer:red,marker:red,bg+:237' \
    --bind 'tab:toggle+down,shift-tab:toggle+up'
)

# 6. Safety Confirmation & Execution
if [[ -n "$selected" ]]; then
    # Zsh Magic: Split newline-delimited string into array
    local -a files
    files=("${(@f)selected}")

    print "\n${COLOR[YELLOW]}You are about to %BPERMANENTLY%b delete:${COLOR[RESET]}"

    # Print list with red formatting
    for f in "${files[@]}"; do
        print "  ${COLOR[RED]}‚úė${COLOR[RESET]} $f"
    done

    # The "Are you sure?" Prompt
    print -n "\n${COLOR[BOLD]}${COLOR[RED]}Are you sure? [y/N]${COLOR[RESET]} "

    # Read 1 character (q)uickly
    if read -q choice; then
        print # Newline after keypress

        # !!! CRITICAL: The actual deletion
        command rm -rf "${files[@]}"

        if [[ $? -eq 0 ]]; then
                print "\n${COLOR[GREEN]}‚úĒ Deleted successfully.${COLOR[RESET]}"
        else
                print "\n${COLOR[RED]}‚úė Error deleting files.${COLOR[RESET]}"
        fi
    else
        print
        print "\n${COLOR[GREEN]}::${COLOR[RESET]} Cancelled."
    fi
else
    print "\n${COLOR[DIM]}:: No files selected.${COLOR[RESET]}"
fi

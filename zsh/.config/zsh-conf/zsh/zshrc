# ------------------------------------------------------------------------------
# File Purpose
#   This script acts as the "Engine Room" of the Zsh configuration.
#   It is responsible for modular loading, background optimization, and
#   applying the final layer of user settings.
#
# Problems Solved
#   - Breaks config into manageable chunks (modules) instead of one huge file.
#   - Compiles scripts to bytecode (.zwc) in the background for speed.
#   - Prevents recursive loading of Tmux.
#   - Handles non-login shell edge cases.
#
# Features / Responsibilities
#   - Environment Safety Checks.
#   - Conditional Module Loading (Tmux, Vi-mode).
#   - Auto-Compilation (Self-healing performance).
#   - Private Config Injection.
#
# Usage Notes
#   - Modules in 'conf.d' are loaded in the order defined in the arrays.
#   - Background compilation happens silently; you won't see output.
# ------------------------------------------------------------------------------


# Safety Check & Environment Restoration
# ─────────────────────────────────────────────────────────────────────────────────
## In some non-login shells (e.g., executing a script, some IDE terminals),
## user.conf might be skipped. We ensure critical variables are loaded here.

if [[ -z "$ZSH_CONFIG_ROOT" ]]; then
    # Fallback if user.conf wasn't sourced (e.g., specific non-login shells)
    [[ -f "${ZDOTDIR:-$HOME/.config/zsh-conf}/user.conf" ]] \
        && source "${ZDOTDIR:-$HOME/.config/zsh-conf}/user.conf" \
        || return
fi


# Feature: Auto-Tmux Integration
# ─────────────────────────────────────────────────────────────────────────────────
## conditionally launches Tmux. We use the ':l' modifier to lowercase the
## {:l} variable for case-insensitive comparison ("Yes" == "yes").

if [[ "${ENABLE_AUTO_TMUX:l}" == "yes" ]] && (( $+commands[tmux] )) && [[ -z "$TMUX" && -t 0 ]]; then
    # Only load if we are NOT already inside a Tmux session or Tmux is enabled by user.
    [[ -f "$ZSH_CONFIG_ROOT/plugins/_tmux" ]] && source "$ZSH_CONFIG_ROOT/plugins/_tmux"
fi


# Module Loading System
# ─────────────────────────────────────────────────────────────────────────────────
## Iterates through distinct configuration files.
## We separate them into "Core" (Essential) and "Auxiliary" (Nice to have).

# ------------------------------------------------------------------------------
# Core Modules
# These define the shell's behavior, appearance, and input handling.

typeset -a core_modules
core_modules=(
    "env"       # Environment variables overrides
    "options"   # Zsh setopt configurations
    "hooks"     # Plugin manager initialization
    "keybinds"  # Key bindings
    "prompt"    # Prompt logic
)

for module in "${core_modules[@]}"; do
    # Source if file exists
    [[ -f "$ZSH_CONFIG_ROOT/conf.d/${module}.zsh" ]] && source "$ZSH_CONFIG_ROOT/conf.d/${module}.zsh"
done

# ------------------------------------------------------------------------------
# Auxiliary Modules
# These are sourced silently to prevent startup noise from minor tools.

function _load_aux_stuff() {
    local aux_modules=("functions" "aliases")

    for module in "${aux_modules[@]}"; do
        local target="$ZSH_CONFIG_ROOT/conf.d/${module}.zsh"
        [[ -f "$target" ]] && source "$target"
    done
}

# Defer the whole operation
zsh-defer _load_aux_stuff

# Defer loading the plugins
zsh-defer source "$ZSH_CONFIG_ROOT/plugins/_init.zsh"

# Background Optimization (Zcompile)
# ─────────────────────────────────────────────────────────────────────────────────
## Zsh can compile text scripts into bytecode (.zwc) for faster parsing.
## This block runs in a background subshell to avoid slowing down startup.

# zsh-defer loads the function _run_background_compilation for the background after the prompt is drawn.
# Detach immediately
# ( ... ) - runs in a subshell.
# &!      - runs in background and disowns the process (suppresses "job finished" messages).
function _run_background_compilation() {
    (

        # Safety & Globbing Options
        # ─────────────────────────────────────────────────────────────────────────────────
        # LOCAL_OPTIONS: Changes don't leak (redundant in subshell but good practice).
        # NO_ALIASES:    Prevent alias expansion from breaking paths.
        # null_glob:     Arrays remain empty if no files match (don't error).
        # extended_glob: Allow recursive globbing (**).
        setopt LOCAL_OPTIONS NO_ALIASES null_glob extended_glob

        # Disable tracing explicitly (just in case)
        unsetopt xtrace verbose

        # Redirect ALL output (stdout & stderr) to the void.
        #    This swallows print, print, errors, AND shell tracing.
        exec >/dev/null 2>&1

        # Atomic Locking
        # ─────────────────────────────────────────────────────────────────────────────────
        # We use `mkdir` because it is an atomic operation on POSIX systems.
        # Two processes cannot create the same directory at the exact same instant.
        # If it fails, another compiler instance is already running.

        local lock_dir="/tmp/zsh_compiling_$USER.lock"

        if ! mkdir "$lock_dir" 2>/dev/null; then
            return 0
        fi

        # Ensure lock is removed on exit, even if the script crashes
        trap "rmdir '$lock_dir'" EXIT


        # Compiler Logic
        # ─────────────────────────────────────────────────────────────────────────────────

        function try_compile() {
            local source_file="$1"
            local compiled_file="${source_file}.zwc"

            # Logic:
            #   - Source file must exist (-f).
            #   - AND ( Compiled file doesn't exist OR Source is newer than Compiled ).
            if [[ -f "$source_file" && ( ! -f "$compiled_file" || "$source_file" -nt "$compiled_file" ) ]]; then

                # zcompile flags:
                #   -U: Don't expand aliases in the sourced file (safety).
                #   >/dev/null: Silence output (we are in background).
                zcompile -U "$source_file" >/dev/null 2>&1
            fi
        }


        # Target Definitions
        # ─────────────────────────────────────────────────────────────────────────────────
        # Build a list of all files that should be compiled.

        local -a files_to_compile

        # ── Core Dotfiles ─────────────────────────────────────────────────

        files_to_compile+=(
            "$HOME/.zshrc"
            "$HOME/.zshenv"
            "$ZSH_CONFIG_ROOT"/zshrc
            "$ZSH_CONFIG_ROOT"/zshrc.mini
            "${ZDOTDIR:-$HOME/.config/zsh-conf}/.zshrc"
            "${ZDOTDIR:-$HOME/.config/zsh-conf}/.zshenv"
            "$ZSH_COMPLETION_DUMP"
        )

        # ── Framework Core (Flat structure) ────────────────────────────────

        # Match all files recursively, BUT exclude (*.zwc)
        # (N.) means: Nullglob (no error if empty) AND Plain files only (no directories)
        files_to_compile+=(
            "$ZSH_CONFIG_ROOT"/conf.d/*.zsh(N)
            "$ZSH_CONFIG_ROOT"/lib/*~*.zwc(N.)
            "$ZSH_CONFIG_ROOT"/lib/functions/*~*.zwc(N.)
        )

        # ── Plugins (Recursive structure) ──────────────────────────────────

        # We need to find .zsh files deep inside plugin directories.
        # We also explicitly look for .plugin.zsh to be safe.
        files_to_compile+=(
            "$ZSH_CONFIG_ROOT"/plugins/*~*.zwc(N.)
            "$ZPLUGIN_STORAGE_DIR"/**/*.zsh(N)
            "$ZPLUGIN_STORAGE_DIR"/**/*.plugin.zsh(N)
        )


        # Execution Loop
        # ─────────────────────────────────────────────────────────────────────────────────

        for file in "${files_to_compile[@]}"; do
            try_compile "$file"
        done


        # EXECUTION: DIRECTORY DIGEST (MULTI-FOLDER)
        # ─────────────────────────────────────────────────────────────────────────────────
        # Compiles specific directories into .zwc files for faster autoloading.

        # Define the directories you want to compile
        #    (Paths relative to ZSH_CONFIG_ROOT or absolute paths)
        local compile_dirs=(
            "${ZSH_CONFIG_ROOT}/conf.d/annexes"
            "${ZSH_CONFIG_ROOT}/plugins/annexes"
        )

        # Loop through them
        for func_dir in $compile_dirs; do
            # Skip if directory doesn't exist
            [[ -d "$func_dir" ]] || continue

            # Define the target digest file (e.g., folder.zwc)
            local digest_file="${func_dir}.zwc"

            # Find the single newest file in the folder to compare timestamps
            # (.om[1]) = regular files (.), ordered by mod time (om), take 1st ([1])
            local newest_src
            newest_src=( "$func_dir"/*(.om[1]) )

            # Check Condition:
            #    - If digest doesn't exist OR
            #    - If the newest source file is newer (-nt) than the digest
            if [[ -n "$newest_src" && ( ! -f "$digest_file" || "$newest_src" -nt "$digest_file" ) ]]; then

                # Compile!
                # -U: No aliases expansion
                # -z: Mark as autoloadable functions (Crucial for fpath)
                # -M: Map the file into memory (optional, often safer to omit in auto-scripts)
                zcompile -U -z "$digest_file" "$func_dir"/*(.N) >/dev/null 2>&1
            fi
        done

    ) &!
}

if (( $+functions[zsh-defer] )); then
    zsh-defer _run_background_compilation
else
    _run_background_compilation
fi


